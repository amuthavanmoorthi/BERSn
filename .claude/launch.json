{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend API",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "Backend",
      "port": 4000
    },
    {
      "name": "FrontEnd (React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "FrontEnd/bern3",
      "port": 3000
    },
    {
      "name": "CalEngine API",
      "runtimeExecutable": "node",
      "runtimeArgs": ["src/server.js"],
      "cwd": "CalEngine/services/api",
      "port": 8080
    },
    {
      "name": "CalEngine Calc (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8001"],
      "cwd": "CalEngine/services/calc",
      "port": 8001
    },
    {
      "name": "CalEngine UI (Vue)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "CalEngine/services/ui",
      "port": 5173
    }
  ]
}

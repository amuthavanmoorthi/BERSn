PORT=4000
NODE_ENV=development
API_TRUST_PROXY=0

DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=bersn_auth
DB_USER=postgres
DB_PASSWORD=postgres
npm run db:migrate

REDIS_URL=redis://127.0.0.1:6379

AUTH_BOOTSTRAP_ADMIN_USERNAME=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_BOOTSTRAP_ADMIN_ROLE=SYS_ADMIN
AUTH_BOOTSTRAP_ADMIN_FORCE=false

AUTH_JWT_ISSUER=bersn-backend
AUTH_JWT_AUDIENCE=bersn-frontend
AUTH_JWT_PRIVATE_KEY_PEM=
AUTH_JWT_PUBLIC_KEY_PEM=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# Email delivery:
# - Keep AUTH_EMAIL_LOG_ONLY=true for local log-only mode
# - Set AUTH_EMAIL_LOG_ONLY=false and provide SMTP settings below to send real emails
# - AUTH_EMAIL_FROM should be a real sender address allowed by your SMTP provider
AUTH_EMAIL_FROM=BERSn <amuthavanmoorthi@gmail.com>
AUTH_EMAIL_LOG_ONLY=true
AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_SECURE=false
AUTH_SMTP_USER=
AUTH_SMTP_PASSWORD=ydcp kprw xodr ryut
AUTH_WEBAUTHN_RP_NAME=BERSn
AUTH_WEBAUTHN_RP_ID=localhost
AUTH_WEBAUTHN_ORIGINS=http://localhost:5173,http://localhost:3000
AUTH_WEBAUTHN_TIMEOUT_MS=60000
AUTH_WEBAUTHN_CHALLENGE_TTL_SECONDS=300
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=604800
AUTH_REMEMBER_ME_REFRESH_TTL_SECONDS=2592000
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_LOCKOUT_MAX_FAILURES=5
AUTH_LOCKOUT_WINDOW_SECONDS=900
AUTH_LOCKOUT_DURATION_SECONDS=900
